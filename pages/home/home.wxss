/* home.wxss */
.page-container {
  min-height: 100vh;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content-container {
  width: 100%;
  padding: 64rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 成功图标 */
.success-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 64rpx;
}

/* 标题 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 32rpx;
}

/* 副标题 */
.subtitle {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 96rpx;
}

/* 退出按钮 */
.logout-btn {
  width: 100%;
  height: 100rpx;
  background-color: #e0e0e0;
  color: #000000;
  border: none;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 100rpx;
}

.logout-btn::after {
  border: none;
}

.btn-hover {
  opacity: 0.8;
}
