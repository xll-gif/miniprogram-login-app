<!--login.wxml-->
<view class="container">
  <image class="logo" src="https://cdn.weipaitang.com/sky/resourceMan/tupianfv/image/20260303/594f688d556e4a78bd597508c9ebd709-W140H140" mode="aspectFit"></image>

  <text class="title">欢迎登录</text>

  <view class="input-group">
    <input class="input" placeholder="请输入用户名" bindinput="onUsernameInput" />
  </view>

  <view class="input-group">
    <input class="input" type="password" placeholder="请输入密码" bindinput="onPasswordInput" />
  </view>

  <text class="error" wx:if="{{errorMessage}}">{{errorMessage}}</text>

  <button class="login-btn" bindtap="onLogin" disabled="{{isLoading}}">
    {{isLoading ? '登录中...' : '登录'}}
  </button>
</view>
