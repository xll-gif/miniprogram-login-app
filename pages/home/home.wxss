/* home.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 24px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 16px;
}

.subtitle {
  font-size: 18px;
  color: #999999;
  margin-bottom: 48px;
}

.logout-btn {
  width: 200px;
  height: 40px;
  background-color: #cccccc;
  color: #ffffff;
  border: none;
  border-radius: 4px;
  font-size: 14px;
}
