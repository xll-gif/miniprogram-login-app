/* login.wxss */
.page-container {
  min-height: 100vh;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content-container {
  width: 100%;
  padding: 64rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo */
.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 64rpx;
}

/* 标题 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 96rpx;
}

/* 输入框容器 */
.input-container {
  width: 100%;
  margin-bottom: 48rpx;
}

/* 输入项 */
.input-item {
  display: flex;
  align-items: center;
  width: 100%;
  height: 100rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  padding: 0 32rpx;
}

.input-item:last-child {
  margin-bottom: 0;
}

/* 输入图标 */
.input-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
  opacity: 0.6;
}

/* 输入框 */
.input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #000000;
}

.input-placeholder {
  color: #999999;
}

/* 错误提示 */
.error {
  width: 100%;
  font-size: 28rpx;
  color: #ff0000;
  height: 40rpx;
  line-height: 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.error-placeholder {
  width: 100%;
  height: 40rpx;
  margin-bottom: 24rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 100rpx;
  background-color: #1890ff;
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 100rpx;
}

.login-btn[disabled] {
  background-color: #cccccc;
  opacity: 0.8;
}

.login-btn::after {
  border: none;
}

.btn-hover {
  opacity: 0.8;
}

/* 加载动画 */
.loading {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #ffffff;
  border-top-color: transparent;
  border-radius: 50%;
  animation: rotate 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
