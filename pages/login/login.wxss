/* login.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 24px;
  background-color: #ffffff;
}

.logo {
  width: 100px;
  height: 100px;
  margin-bottom: 48px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 32px;
}

.input-group {
  width: 100%;
  margin-bottom: 16px;
}

.input {
  width: 300px;
  height: 40px;
  padding: 0 12px;
  border: 1px solid #d9d9d9;
  border-radius: 4px;
  font-size: 14px;
}

.error {
  font-size: 14px;
  color: #ff0000;
  margin-bottom: 16px;
}

.login-btn {
  width: 200px;
  height: 40px;
  background-color: #1890ff;
  color: #ffffff;
  border: none;
  border-radius: 4px;
  font-size: 14px;
}

.login-btn[disabled] {
  background-color: #cccccc;
}
